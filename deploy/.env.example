# =============================================================================
# Mental Gaming Store — VPS Environment Variables
# =============================================================================
# ဒီ file ကို VPS ပေါ်မှာ `.env` အဖြစ် copy ကူးပြီး တန်ဖိုးတွေ ဖြည့်ပါ:
#   cp deploy/.env.example .env
# ⚠️ .env ကို git ထဲ ဘယ်တော့မှ မတင်ပါနဲ့ (secret တွေပါတယ်)
# =============================================================================

# ---- Telegram Bot ----
BOT_TOKEN=            # @BotFather ကရတဲ့ bot token
BOT_USERNAME=         # bot ရဲ့ username (@ မပါ) — ဥပမာ MentalGamingBot
ADMIN_ID=             # owner ရဲ့ Telegram numeric user ID

# ---- Database (MongoDB Atlas ကို recommend) ----
MONGODB_URI=          # mongodb+srv://user:pass@cluster.mongodb.net/dbname

# ---- AI (Gemini) ----
AI_API_KEY=           # Gemini API key

# ---- Security ----
SESSION_SECRET=       # backup encryption key (ရှည်ပြီး ခန့်မှန်းရခက်တဲ့ string)

# ---- Payment / Provider APIs (optional — မသုံးရင် ဗလာထားလို့ရ) ----
SMILEONE_USER_ID=
SMILEONE_SECRET=
UNIPIN_API_KEY=

# ---- API Server ----
PORT=8000             # api-server listen port (Nginx က ဒီ port ကို proxy လုပ်မယ်)
NODE_ENV=production
LOG_LEVEL=info
